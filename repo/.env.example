DATABASE_URL=mysql://root:root@localhost/brewflow
RUST_LOG=info

# Session signing key (HMAC-SHA256) — generate with: openssl rand -hex 32
COOKIE_SECRET=replace-with-32-byte-hex-secret

# AES-256-GCM key for voucher encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-32-byte-hex-key

# Comma-separated allowed CORS origins (e.g. http://intranet.example.com)
# Leave empty to disallow all cross-origin requests.
ALLOWED_ORIGINS=http://localhost:8080

# Base URL used in sitemap.xml / robots.txt (no trailing slash)
# Set to your intranet hostname in production.
SITEMAP_BASE_URL=http://localhost:8080
